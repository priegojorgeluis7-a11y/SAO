# ─── SAO Backend — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in the real values.
# Never commit .env to version control.

ENV=development
DATABASE_URL=postgresql://sao:sao123@localhost:5432/sao_db
JWT_SECRET=replace-with-strong-secret-in-production

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,https://sao-api-fjzra25vya-uc.a.run.app

SIGNUP_INVITE_CODE=replace-in-runtime
ADMIN_INVITE_CODE=optional-admin-invite

# ── Google Cloud Storage (producción) ──
GCS_BUCKET=sao-evidencias-prod

# ── Evidencias: "local" (dev, guarda en disco) | "gcs" (staging/prod) ──
EVIDENCE_STORAGE_BACKEND=gcs
LOCAL_BASE_URL=http://localhost:8000
LOCAL_UPLOADS_DIR=./uploads
